{
  "name": "Employment Info",
  "order": 2,
  "path": "/profile/employment",
  "load_criteria": {
    "condition": "visible",
    "locator": {
      "by": "id",
      "value": "employment-form"
    },
    "timeout": 20,
    "require_document_ready": true,
    "require_ajax_idle": true
  },
  "sections": [
    {
      "name": "Employment",
      "order": 1,
      "elements": [
        {
          "name": "Employer",
          "type": "text",
          "action": "input",
          "locator": {
            "by": "name",
            "value": "employer"
          },
          "value": "Acme Corp"
        },
        {
          "name": "Save",
          "type": "button",
          "action": "click",
          "locator": {
            "by": "id",
            "value": "saveButton"
          },
          "post_wait": {
            "condition": "text_contains",
            "locator": {
              "by": "css_selector",
              "value": ".toast-message"
            },
            "text_expected": "saved successfully",
            "timeout": 20,
            "spinner_locator": {
              "by": "css_selector",
              "value": ".loading-mask"
            }
          }
        }
      ]
    }
  ]
}
