{
  "name": "Form Demo",
  "order": 1,
  "pages": [
    {
      "name": "Login Page",
      "order": 1,
      "path": "/login",
      "load_criteria": {
        "condition": "visible",
        "locator": {
          "by": "id",
          "value": "login"
        },
        "timeout": 15,
        "require_document_ready": true
      },
      "sections": [
        {
          "name": "Credentials",
          "order": 1,
          "elements": [
            {
              "name": "Username",
              "type": "text",
              "action": "input",
              "locator": {
                "by": "id",
                "value": "username"
              },
              "value": "tomsmith",
              "required": true
            },
            {
              "name": "Password",
              "type": "text",
              "action": "input",
              "locator": {
                "by": "id",
                "value": "password"
              },
              "value": "SuperSecretPassword!",
              "required": true
            },
            {
              "name": "Login Button",
              "type": "button",
              "action": "click",
              "locator": {
                "by": "css_selector",
                "value": "button[type='submit']"
              },
              "post_wait": {
                "condition": "visible",
                "locator": {
                  "by": "css_selector",
                  "value": ".flash.success"
                },
                "timeout": 10
              }
            }
          ]
        }
      ]
    }
  ]
}
