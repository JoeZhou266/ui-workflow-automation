# Copy this file to .env and fill in values for your environment

# Base URL override (overrides env yaml if set)
BASE_URL=

# Browser: chrome | firefox | edge
BROWSER=chrome

# Run headless
HEADLESS=false

# Default implicit wait (keep at 0 for explicit-only strategy)
IMPLICIT_WAIT=0

# Default page load timeout seconds
PAGE_LOAD_TIMEOUT=30

# Screenshots directory
SCREENSHOTS_DIR=reports/screenshots

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
